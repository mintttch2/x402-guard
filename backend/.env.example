# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# The chat / channel ID that will receive notifications.
# For a personal chat: forward a message from your bot to @userinfobot to find your ID.
# For a channel: use the channel username (e.g. @mychannel) or numeric ID.
TELEGRAM_CHAT_ID=

# ── Discord ───────────────────────────────────────────────────────────────────
# Create an Incoming Webhook in your Discord server's channel settings and paste the URL.
DISCORD_WEBHOOK_URL=

# ── Backend ───────────────────────────────────────────────────────────────────
# Public URL of this backend, used to generate "View Dashboard" links in notifications.
BACKEND_URL=http://localhost:4402

# ── Notification spam-guard ───────────────────────────────────────────────────
# Minimum seconds between two notifications for the same agent (default: 60).
NOTIFICATION_COOLDOWN_SECONDS=60

# ── Optional: CORS origins ────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: data directory ──────────────────────────────────────────────────
# Where policies.json and transactions.json are stored (default: ./data/).
# X402_DATA_DIR=/var/lib/x402-guard/data

# ── X Layer onchain logging ────────────────────────────────────────────────────
# Deploy contracts/GuardLog.sol and paste the address here to enable onchain
# logging of every guard decision.  If either var is missing, logging is silently
# skipped so the backend works without blockchain connectivity.
GUARD_CONTRACT_ADDRESS=
GUARDIAN_PRIVATE_KEY=
XLAYER_RPC_URL=https://testrpc.xlayer.tech
# XLAYER_CHAIN_ID=195    # 195 = testnet, 196 = mainnet

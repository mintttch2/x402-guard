# x402 Guard — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# REQUIRED = core app expects a real value for normal end-to-end operation
# OPTIONAL = leave empty to disable that integration while keeping the app usable

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=8000
DEV=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Telegram alerts (OPTIONAL) ────────────────────────────────────────────────
# Leave both empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord alerts (OPTIONAL) ─────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── OKX OnchainOS / OKX Web3 API (OPTIONAL) ──────────────────────────────────
# Leave empty if you only want to run the local dashboard / guard without OKX API features.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# ── X Layer on-chain audit (OPTIONAL) ─────────────────────────────────────────
# Leave GUARDIAN_PRIVATE_KEY empty to disable GuardLog writes while keeping local logging.
XLAYER_RPC_URL=https://testrpc.xlayer.tech
GUARD_CONTRACT_ADDRESS=0xaC4bbC6A7bA52622c1dF942A309CB6D835D363bB
GUARDIAN_PRIVATE_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

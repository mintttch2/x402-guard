# ── x402 Guard — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4402
DEV=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Obtain a bot token from @BotFather, then send a message to your bot and
# retrieve the chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord alerts ────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── OKX OnchainOS / OKX Web3 API ─────────────────────────────────────────────
# Required for OKX Agentic Wallet integration, DEX trades, and token data.
# Get credentials at: https://www.okx.com/web3/build/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# ── X Layer on-chain audit (optional) ────────────────────────────────────────
# Set these to enable logDecision() calls to GuardLog.sol on X Layer (chainId 196)
XLAYER_RPC_URL=https://rpc.xlayer.tech
GUARDLOG_CONTRACT_ADDRESS=
GUARDIAN_PRIVATE_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
